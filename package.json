{
  "name": "originium-kernel",
  "version": "0.1.0",
  "private": true,
  "telemetry": false,
  "scripts": {
    "dev": "bun run next dev",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "check": "bun run type-check && bun run lint",
    "db:init": "node scripts/db-init.js",
    "db:generate": "PRISMA_HIDE_UPDATE_MESSAGE=true PRISMA_HIDE_PREVIEW_FLAG_WARNINGS=true prisma generate",
    "db:push": "PRISMA_HIDE_UPDATE_MESSAGE=true PRISMA_HIDE_PREVIEW_FLAG_WARNINGS=true prisma db push",
    "db:migrate": "PRISMA_HIDE_UPDATE_MESSAGE=true PRISMA_HIDE_PREVIEW_FLAG_WARNINGS=true prisma migrate dev",
    "db:studio": "PRISMA_HIDE_UPDATE_MESSAGE=true PRISMA_HIDE_PREVIEW_FLAG_WARNINGS=true prisma studio",
    "build": "NEXT_TELEMETRY_DISABLED=1 bun run check && bun run db:generate && bun run db:init && bun run next build",
    "start": "bun run next start",
    "clean": "bun run next clean"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@lobehub/ui": "^5.5.2",
    "@prisma/client": "^6.19.2",
    "@types/node": "^20",
    "@types/react-syntax-highlighter": "^15.5.13",
    "antd": "^6.1.1",
    "antd-style": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "octokit": "^5.0.5",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19",
    "eslint": "9.39.1",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.3"
  }
}
