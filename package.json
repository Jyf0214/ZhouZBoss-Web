{
  "name": "originium-kernel",
  "version": "0.1.0",
  "private": true,
  "telemetry": false,
  "scripts": {
    "dev": "next dev",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "check": "npm run type-check && npm run lint",
    "db:init": "node scripts/db-init.mjs",
    "db:generate": "PRISMA_HIDE_UPDATE_MESSAGE=true PRISMA_HIDE_PREVIEW_FLAG_WARNINGS=true prisma generate",
    "db:push": "PRISMA_HIDE_UPDATE_MESSAGE=true PRISMA_HIDE_PREVIEW_FLAG_WARNINGS=true prisma db push",
    "db:migrate": "PRISMA_HIDE_UPDATE_MESSAGE=true PRISMA_HIDE_PREVIEW_FLAG_WARNINGS=true prisma migrate dev",
    "db:studio": "PRISMA_HIDE_UPDATE_MESSAGE=true PRISMA_HIDE_PREVIEW_FLAG_WARNINGS=true prisma studio",
    "build": "NEXT_TELEMETRY_DISABLED=1 npm run check && npm run test && npm run db:generate && npm run db:init && next build",
    "test": "vitest run",
    "start": "next start",
    "clean": "next clean",
    "prepare": "husky"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@clerk/localizations": "^4.5.7",
    "@clerk/nextjs": "^7.2.9",
    "@prisma/client": "^6.19.2",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react-syntax-highlighter": "^15.5.13",
    "antd": "^6.1.1",
    "antd-style": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^16.2.4",
    "next-intl": "^4.8.3",
    "nodemailer": "^8.0.4",
    "octokit": "^5.0.5",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "svix": "^1.92.2",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "9.39.1",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.1",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
