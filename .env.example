# Originium Kernel Environment Variables
# 环境变量配置说明 - 复制此文件为 .env.local 并填入实际值

# ============================================
# 必需的环境变量 (Required)
# ============================================

# 数据库连接 URL
# 支持 Redis/MySQL/PostgreSQL
# Redis 示例：redis://localhost:6379
# Upstash Redis: redis://default:password@host:port
# MySQL 示例：mysql://user:password@localhost:3306/database
# PostgreSQL 示例：postgresql://user:password@localhost:5432/database
DATABASE_URL="redis://localhost:6379"

# 会话加密密钥 (至少 32 字符)
# 生成方法：openssl rand -base64 32
# 或：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="your-secret-key-at-least-32-characters-long-change-this-in-production"

# ============================================
# Clerk 认证 (可选，第三方登录)
# ============================================
# 在 https://dashboard.clerk.com 创建应用后获取
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxx"
# CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxx"
# CLERK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxx"  # 用于 Clerk Webhook 签名验证

# ============================================
# SMTP 邮件服务 (可选，账户绑定验证码)
# ============================================
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"

# ============================================
# 可选的环境变量 (Optional)
# ============================================

# 应用 URL (用于回调等)
APP_URL="http://localhost:3000"

# GitHub 集成 (用于内容同步)
# GITHUB_REPO="username/repo-name"
# GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"

# 定时任务密钥
# CRON_SECRET="your-cron-secret"
