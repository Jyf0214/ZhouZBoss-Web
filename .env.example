# Originium Kernel Environment Variables
# 环境变量配置说明 - 复制此文件为 .env.local 并填入实际值

# ============================================
# 必需的环境变量 (Required)
# ============================================

# 数据库连接 URL
# 支持 Redis/MySQL/PostgreSQL
# Redis 示例：redis://localhost:6379
# Upstash Redis: redis://default:password@host:port
# MySQL 示例：mysql://user:password@localhost:3306/database
# PostgreSQL 示例：postgresql://user:password@localhost:5432/database
DATABASE_URL="redis://localhost:6379"

# 会话加密密钥 (至少 32 字符)
# 生成方法：openssl rand -base64 32
# 或：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="your-secret-key-at-least-32-characters-long-change-this-in-production"

# ============================================
# 可选的环境变量 (Optional)
# ============================================

# 应用 URL (用于回调等)
APP_URL="http://localhost:3000"

# GitHub 集成 (用于内容同步)
# GITHUB_REPO="username/repo-name"
# GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"

# 定时任务密钥
# CRON_SECRET="your-cron-secret"

# Gemini API Key (AI 功能)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
