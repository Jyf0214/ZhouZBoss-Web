// Prisma schema - Originium Kernel Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  uid           String    @id @default(cuid())
  email         String    @unique
  username      String?   @unique
  name          String
  password      String
  role          String    @default("user")
  userGroup     String?   @map("user_group")
  status        String    @default("active")
  clerkId       String?   @unique @map("clerk_id")
  clerkLinkedAt DateTime? @map("clerk_linked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
  @@index([email])
  @@index([uid])
  @@index([username])
  @@index([clerkId])
}

// 用户组表
model UserGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_groups")
}

// KV 存储表
model OriginiumKV {
  key       String   @id @map("k")
  value     String?  @map("v")
  expiry    BigInt?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("originium_kv")
  @@index([key])
}

// 日记表
model Diary {
  id        String   @id @default(cuid())
  title     String
  content   String
  tags      String[] @default([])
  group     String?  @default("默认")
  references Json?   @default("[]")
  date      DateTime @default(now()) @map("diary_date")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("diaries")
  @@index([date])
  @@index([createdAt])
  @@index([pinned])
  @@index([group])
}

// 文章删除申请表
model Request {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  userName  String   @map("user_name")
  postSlug  String   @map("post_slug")
  postTitle String   @map("post_title")
  reason    String?
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("requests")
  @@index([userId])
  @@index([status])
  @@index([postSlug])
}
