// Prisma schema - Originium Kernel Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  uid           String    @id @default(cuid())
  email         String    @unique
  username      String?   @unique
  name          String
  password      String
  role          String    @default("user")
  userGroup     String?   @map("user_group")
  status        String    @default("active")
  clerkId       String?   @unique @map("clerk_id")
  clerkLinkedAt DateTime? @map("clerk_linked_at")
  twoFactorSecret  String?   @map("two_factor_secret")
  twoFactorEnabled Boolean   @default(false) @map("two_factor_enabled")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

// KV 存储表
model OriginiumKV {
  key       String   @id @map("k")
  value     String?  @map("v")
  expiry    BigInt?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("originium_kv")
}

// 日记表
model Diary {
  id        String   @id @default(cuid())
  title     String
  content   String
  tags      String[] @default([])
  group     String?  @default("默认")
  references Json?   @default("[]")
  date      DateTime @default(now()) @map("diary_date")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("diaries")
  @@index([date])
  @@index([createdAt])
  @@index([pinned])
  @@index([group])
}

// 文章删除申请表
model Request {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  userName  String   @map("user_name")
  postSlug  String   @map("post_slug")
  postTitle String   @map("post_title")
  reason    String?
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("requests")
  @@index([userId])
  @@index([status])
  @@index([postSlug])
}

// 存储池文件夹元数据(WebDAV 顶层文件夹可见性控制)
// 注意:此表只存文件夹级别的元数据,不存文件内容/文件名清单
model StorageFolder {
  path        String   @id          // 文件夹相对路径,如 "covers" 或 "covers/2024"(无前导斜杠,无尾斜杠,顶层为空字符串表示根)
  public      Boolean  @default(false) @map("is_public")
  description String?
  password    String?                // 私有页面访问密码(明文),null = 未设密码(私有但失败安全)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("storage_folders")
  @@index([public])
}

// API 密钥表(替代 Cookie 的无状态认证方式)
model ApiKey {
  id        String    @id @default(cuid())
  uid       String                     // 关联用户 UID
  key       String    @unique          // sk-xxx 明文哈希(仅创建时返回原文明文)
  name      String                     // 用户自定义名称(如 "iOS App")
  lastUsed  DateTime? @map("last_used")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("api_keys")
  @@index([uid])
}

// 临时分享链接表(存储池文件/文件夹的有时效分享)
model ShareLink {
  id        Int      @id @default(autoincrement())
  token     String   @unique          // 随机 token(crypto.randomUUID)
  path      String                    // 文件/文件夹路径
  password  String?                   // 可选密码(明文,与项目现有风格一致)
  expiresAt DateTime                  // 过期时间
  createdAt DateTime @default(now()) @map("created_at")

  @@map("share_links")
  @@index([token])
  @@index([expiresAt])
}

// 审计日志表(不可篡改操作记录)
model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String   // 操作类型: config.update, user.delete, storage.upload 等
  target    String   // 操作对象: "config" / "user:123" / "storage:pages/hello.html"
  detail    String?  // 操作详情(JSON 字符串)
  userId    String   @map("user_id") // 操作者
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
  @@index([action])
  @@index([userId])
  @@index([createdAt])
}
