// Prisma schema - Originium Kernel Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  uid           String    @id @default(cuid())
  email         String    @unique
  username      String?   @unique
  name          String
  password      String
  role          String    @default("user")
  userGroup     String?   @map("user_group")
  status        String    @default("active")
  clerkId       String?   @unique @map("clerk_id")
  clerkLinkedAt DateTime? @map("clerk_linked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

// KV 存储表
model OriginiumKV {
  key       String   @id @map("k")
  value     String?  @map("v")
  expiry    BigInt?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("originium_kv")
}

// 日记表
model Diary {
  id        String   @id @default(cuid())
  title     String
  content   String
  tags      String[] @default([])
  group     String?  @default("默认")
  references Json?   @default("[]")
  date      DateTime @default(now()) @map("diary_date")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("diaries")
  @@index([date])
  @@index([createdAt])
  @@index([pinned])
  @@index([group])
}

// 文章删除申请表
model Request {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  userName  String   @map("user_name")
  postSlug  String   @map("post_slug")
  postTitle String   @map("post_title")
  reason    String?
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("requests")
  @@index([userId])
  @@index([status])
  @@index([postSlug])
}

// 存储池文件夹元数据(WebDAV 顶层文件夹可见性控制)
// 注意:此表只存文件夹级别的元数据,不存文件内容/文件名清单
model StorageFolder {
  path        String   @id          // 文件夹相对路径,如 "covers" 或 "covers/2024"(无前导斜杠,无尾斜杠,顶层为空字符串表示根)
  public      Boolean  @default(false) @map("is_public")
  description String?
  password    String?                // 私有页面访问密码(明文),null = 未设密码(私有但失败安全)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("storage_folders")
  @@index([public])
}

/// 存储池操作审计日志(rmdir / mkdir / upload / delete_file / set_public / set_password)
model StorageAuditLog {
  id        String   @id @default(cuid())
  actorUid  String?  @map("actor_uid")    // null = 系统操作
  action    String                         // 'rmdir' | 'mkdir' | 'upload' | 'delete_file' | 'set_public' | 'set_password'
  path      String                         // 受影响路径
  metadata  Json?                          // 递归删除条数、文件大小等扩展上下文
  at        DateTime @default(now()) @map("at")

  @@map("storage_audit_logs")
  @@index([actorUid])
  @@index([action])
  @@index([at])
}
